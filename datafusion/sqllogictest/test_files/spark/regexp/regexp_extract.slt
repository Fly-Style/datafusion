# Test of regexp_extract function with scalar 'str' input (Original Spark)
query T
SELECT regexp_extract('a b', 'a (b)', 1);
----
b

query T
SELECT regexp_extract('a123b', '(\d+)', 1);
----
123

query T
SELECT regexp_extract('hello world', 'hello (world)', 0);
----
hello world

query T
SELECT regexp_extract('hello world', 'xxf', 0);
----
(empty)

query T
SELECT regexp_extract('100-200-300-400', '(\d+)-(\d+)-(\d+)-(\d+)', 3);
----
300

# Test with non-existent capture group index
query T
SELECT regexp_extract('100-200', '(\d+)-(\d+)', 3);
----
(empty)

# Test with empty input string
query T
SELECT regexp_extract('', '(\d+)', 1);
----
(empty)

# Test with optional capture groups
query T
SELECT regexp_extract('abc', '(a)(b)?(c)', 2);
----
b

# Test with complex patterns
query T
SELECT regexp_extract('2025-08-05', '(\d{4})-(\d{2})-(\d{2})', 1);
----
2025

query T
SELECT regexp_extract('2025-08-05', '(\d{4})-(\d{2})-(\d{2})', 2);
----
08

query T
SELECT regexp_extract('2025-08-05', '(\d{4})-(\d{2})-(\d{2})', 3);
----
05

# Test of regexp_extract function with column 'str' input (PySpark-like)
statement ok
CREATE TABLE t(a TEXT) AS VALUES ('100-200'), ('300-400'), ('500-600');

query T
SELECT regexp_extract(a, '(\d+)-(\d+)', 1) FROM t;
----
100
300
500

# Test for PySpark-like case with mixed NULL and non-NULL values in a column
statement ok
CREATE TABLE t2(a TEXT) AS VALUES ('100-200'), (NULL), ('500-600');

query T
SELECT regexp_extract(a, '(\d+)-(\d+)', 2) FROM t2;
----
200
NULL
600

